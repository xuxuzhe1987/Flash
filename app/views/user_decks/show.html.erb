<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Study - Flash</title>
<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    padding: 20px;
  }

  .page-container {
    background: white;
    max-width: 480px;
    width: 100%;
    min-height: calc(100vh - 40px);
    border-radius: 24px;
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.2);
    overflow: hidden;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }

  .page-header {
    padding: 24px 24px 16px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    background: linear-gradient(180deg, rgba(102, 126, 234, 0.08) 0%, transparent 100%);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .back-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: #f8fafc;
    color: #64748b;
    text-decoration: none;
    transition: all 0.2s ease;
    border: 1px solid #e2e8f0;
  }

  .back-link:hover {
    color: #667eea;
    border-color: #667eea;
  }

  .page-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #1a1a2e;
    text-align: center;
    flex: 1;
  }

  .progress-badge {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 24px;
  }

  .flashcard {
    width: 100%;
    min-height: 300px;
    background: white;
    border-radius: 24px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
    border: 2px solid #e2e8f0;
    transition: all 0.3s ease;
  }

  .flashcard:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
  }

  .card-content {
    flex: 1;
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    cursor: pointer;
    min-height: 300px;
  }

  .card-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #667eea;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
  }

  .card-text {
    font-size: 1.5rem;
    font-weight: 600;
    color: #1a1a2e;
    line-height: 1.4;
  }

  .card-actions {
    padding: 20px 24px;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    display: flex;
    gap: 12px;
  }

  .btn-action {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 16px 12px;
    border-radius: 16px;
    font-size: 0.75rem;
    font-weight: 600;
    transition: all 0.2s ease;
    cursor: pointer;
    border: 2px solid;
    background: white;
  }

  .btn-action i {
    font-size: 1.5rem;
    margin-bottom: 6px;
  }

  .btn-know {
    color: #22c55e;
    border-color: #22c55e;
  }

  .btn-know:hover {
    background: #22c55e;
    color: white;
  }

  .btn-flip {
    color: #667eea;
    border-color: #667eea;
  }

  .btn-flip:hover {
    background: #667eea;
    color: white;
  }

  .btn-dont-know {
    color: #ef4444;
    border-color: #ef4444;
  }

  .btn-dont-know:hover {
    background: #ef4444;
    color: white;
  }

  .empty-state {
    text-align: center;
    padding: 60px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .empty-state-icon {
    font-size: 5rem;
    margin-bottom: 20px;
  }

  .empty-state h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 8px;
  }

  .empty-state p {
    color: #64748b;
    margin-bottom: 24px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 24px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
    color: white;
  }

  .stats {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-top: 16px;
  }

  .stat-item {
    text-align: center;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .stat-value.success {
    color: #22c55e;
  }

  .stat-value.error {
    color: #ef4444;
  }

  .stat-label {
    font-size: 0.85rem;
    color: #64748b;
  }

  @media (max-width: 480px) {
    .page-header {
      padding: 20px 16px;
    }

    .content {
      padding: 16px;
    }

    .card-text {
      font-size: 1.3rem;
    }

    .btn-action {
      padding: 12px 8px;
    }

    .btn-action i {
      font-size: 1.2rem;
    }
  }
</style>
</head>
<body>
  <div class="page-container">
    <div class="page-header">
      <a href="/decks/<%= @user_deck.deck.id %>" class="back-link">
        <i class="fas fa-arrow-left"></i>
      </a>
      <h1 class="page-title"><%= @user_deck.deck.name %></h1>
      <% if !@completed %>
        <span class="progress-badge"><%= @progress[:current] %>/<%= @progress[:total] %></span>
      <% else %>
        <span class="progress-badge"><i class="fas fa-check"></i></span>
      <% end %>
    </div>

    <div class="content">
      <% if @completed %>
        <div class="empty-state">
          <div class="empty-state-icon">🎉</div>
          <h3>Congratulations!</h3>
          <p>You've completed all cards!</p>
          
          <div class="stats">
            <div class="stat-item">
              <div class="stat-value success"><%= @progress[:known] %></div>
              <div class="stat-label">Known</div>
            </div>
            <div class="stat-item">
              <div class="stat-value error"><%= @progress[:learning] %></div>
              <div class="stat-label">Learning</div>
            </div>
          </div>
          
          <a href="/decks/<%= @user_deck.deck.id %>" class="btn-primary" style="margin-top: 24px;">
            <i class="fas fa-arrow-left"></i>
            Back to Deck
          </a>
        </div>
      <% else %>
        <div class="flashcard" id="flashcard">
          <div class="card-content" id="question-side">
            <div class="card-label">Question</div>
            <div class="card-text"><%= @current_card.question %></div>
          </div>
          <div class="card-content" id="answer-side" style="display: none; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <div class="card-label" style="color: rgba(255,255,255,0.8);">Answer</div>
            <div class="card-text" style="color: white;"><%= @current_card.answer %></div>
          </div>
        </div>

        <div class="card-actions">
          <form action="/user_decks/<%= @user_deck.id %>/learn" method="POST" style="flex: 1;">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <input type="hidden" name="card_id" value="<%= @current_card.id %>">
            <input type="hidden" name="result" value="false">
            <input type="hidden" name="next_index" value="<%= @next_index %>">
            <button type="submit" class="btn-action btn-dont-know" style="width: 100%;">
              <i class="fas fa-times"></i>
              Don't Know
            </button>
          </form>
          
          <button type="button" class="btn-action btn-flip" onclick="flipCard()" style="flex: 1; width: 100%;">
            <i class="fas fa-sync-alt"></i>
            Flip
          </button>
          
          <form action="/user_decks/<%= @user_deck.id %>/learn" method="POST" style="flex: 1;">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <input type="hidden" name="card_id" value="<%= @current_card.id %>">
            <input type="hidden" name="result" value="true">
            <input type="hidden" name="next_index" value="<%= @next_index %>">
            <button type="submit" class="btn-action btn-know" style="width: 100%;">
              <i class="fas fa-check"></i>
              Know It
            </button>
          </form>
        </div>
      <% end %>
    </div>
  </div>

  <script>
    function flipCard() {
      const questionSide = document.getElementById('question-side');
      const answerSide = document.getElementById('answer-side');
      
      if (questionSide.style.display === 'none') {
        questionSide.style.display = 'flex';
        answerSide.style.display = 'none';
      } else {
        questionSide.style.display = 'none';
        answerSide.style.display = 'flex';
      }
    }
  </script>
</body>
</html>